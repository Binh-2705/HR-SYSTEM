# ============================================================
# HRM SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# Sao chép file này thành .env và điền vào các giá trị thực.
# Không commit file .env thật lên git.
# ============================================================

# ------------------------------------------------------------
# CƠ SỞ DỮ LIỆU (MySQL)
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=quanlynhansu
DB_USERNAME=root
DB_PASSWORD=

# ------------------------------------------------------------
# CHATBOT AI (OpenAI)
# Cần key để chatbot trả lời câu hỏi tự do ngoài intents có sẵn.
# Lấy key tại: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------
# BOT SERVICE (Python FastAPI - chạy trên cổng 8001)
# BOT_SERVICE_URL: PHP gọi vào bot để trò chuyện
# BOT_BRIEF_URL:   PHP lấy tóm tắt nhanh (dashboard widget)
# BOT_STATS_URL:   PHP lấy thống kê toàn hệ thống
# APP_SHARED_SECRET: khóa bí mật dùng chung PHP ↔ bot
#   → Tạo giá trị mạnh: openssl rand -hex 32
#   → Phải khớp với APP_SHARED_SECRET trong bot_service/.env
# ------------------------------------------------------------
BOT_SERVICE_URL=http://127.0.0.1:8001/chat
BOT_BRIEF_URL=http://127.0.0.1:8001/brief
BOT_STATS_URL=http://127.0.0.1:8001/stats
APP_SHARED_SECRET=

# ------------------------------------------------------------
# EMAIL (PHPMailer)
# Local development: dùng Mailhog (MAIL_PORT=1025, không cần auth)
# Production: điền SMTP thật (Gmail, SendGrid, v.v.)
# MAIL_ENCRYPTION: tls | ssl | (để trống)
# ------------------------------------------------------------
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="HRM System"
