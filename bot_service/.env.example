# ============================================================
# BOT SERVICE - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# Sao chép thành .env và điền giá trị thực.
# ============================================================

# ------------------------------------------------------------
# OPENAI - Cần có để chatbot trả lời tự do ngoài intents
# Model mặc định: gpt-4o-mini (tiết kiệm chi phí)
# Thay bằng gpt-4o nếu cần chính xác cao hơn
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# CƠ SỞ DỮ LIỆU MySQL
# Lưu ý: dùng DB_USER (không phải DB_USERNAME)
# ------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=quanlynhansu

# ------------------------------------------------------------
# BẢO MẬT - Shared Secret giữa PHP và bot service
# Phải khớp với APP_SHARED_SECRET trong root .env
# Tạo: openssl rand -hex 32
# ------------------------------------------------------------
APP_SHARED_SECRET=
